# =============================================================================
# LeadForge AI — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ---- App ----
APP_NAME="LeadForge AI"
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Database ----
POSTGRES_USER=leadforge
POSTGRES_PASSWORD=leadforge_secret
POSTGRES_DB=leadforge_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://leadforge:leadforge_secret@postgres:5432/leadforge_db
SYNC_DATABASE_URL=postgresql://leadforge:leadforge_secret@postgres:5432/leadforge_db

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- Google Places API (optional — uses mock adapter if empty) ----
GOOGLE_PLACES_API_KEY=

# ---- Yelp API (optional) ----
YELP_API_KEY=

# ---- OpenAI (optional — uses template generator if empty) ----
OPENAI_API_KEY=

# ---- Scraping Settings ----
CRAWL_DELAY_SECONDS=2
MAX_CONCURRENT_CRAWLS=5
REQUEST_TIMEOUT_SECONDS=15
USE_MOCK_ADAPTER=true

# ---- Export ----
EXPORT_DIR=/app/exports
MAX_EXPORT_ROWS=50000

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=60

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="LeadForge AI"
